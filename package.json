{
  "name": "quick-capture",
  "version": "0.2.5",
  "private": true,
  "repository": "https://github.com/zhengxn1/quick-capture",
  "workspaces": [
    "plugin",
    "worker"
  ],
  "scripts": {
    "lint": "eslint plugin/src",
    "build": "npm run build --workspace plugin && npm run check --workspace plugin && npm run check --workspace worker",
    "test": "npm run test --workspace worker",
    "verify": "npm run lint && npm run build && npm run test",
    "deploy": "node scripts/deploy.mjs",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "^1.13.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
